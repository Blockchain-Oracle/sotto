{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "scripts/diagnostics/**/*.ts",
    "spikes/**/*.ts"
  ],
  // The Next.js apps typecheck with their own bundler-mode tsconfigs via the
  // root typecheck script; NodeNext resolution cannot host them.
  "exclude": ["apps/site", "apps/docs", "apps/app"]
}
