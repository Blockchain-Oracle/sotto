module SottoControlPurchaseTestSupport where

import DA.Time (addRelTime, hours)
import Daml.Script
import Splice.Api.Token.HoldingV1 qualified as Holding
import Splice.Api.Token.MetadataV1 qualified as Metadata
import Splice.Api.Token.TransferInstructionV1 qualified as Transfer
import Sotto.Control.PurchaseCapability
import SottoControlTokenStandardMock

data PurchaseFixture = PurchaseFixture with
  payer : Party
  agent : Party
  provider : Party
  admin : Party
  outsider : Party
  now : Time
  instrumentId : Holding.InstrumentId
  factoryCid : ContractId MockTransferFactory
  holdingCid : ContractId MockHolding
  holdingInterfaceCid : ContractId Holding.Holding
  capabilityCid : ContractId BoundedPurchaseCapability

createPurchaseFixture : FactoryMode -> Text -> Script PurchaseFixture
createPurchaseFixture mode holdingInstrument = do
  payer <- allocateParty "sotto-fixture-payer"
  agent <- allocateParty "sotto-fixture-agent"
  provider <- allocateParty "sotto-fixture-provider"
  admin <- allocateParty "sotto-fixture-admin"
  outsider <- allocateParty "sotto-fixture-outsider"
  now <- getTime
  let instrumentId = Holding.InstrumentId with admin; id = "Amulet"
  let actualHoldingInstrument = Holding.InstrumentId with admin; id = holdingInstrument
  factoryCid <- submit admin do
    createCmd MockTransferFactory with admin; mode
  holdingCid <- submit admin do
    createCmd MockHolding with
      admin
      owner = payer
      instrumentId = actualHoldingInstrument
      amount = 2.0
  let factoryInterfaceCid =
        toInterfaceContractId @Transfer.TransferFactory factoryCid
  let holdingInterfaceCid = toInterfaceContractId @Holding.Holding holdingCid
  capabilityCid <- submit payer do
    createCmd BoundedPurchaseCapability with
      payer
      agent
      resourceBindingVersion = "sotto-resource-v1"
      allowedResourceHash = "sha256:resource"
      allowedRecipient = provider
      instrumentId
      perCallLimit = 2.0
      remainingAllowance = 5.0
      maximumTotalDebit = 2.0
      expiresAt = addRelTime now (hours 2)
      revision = 0
      paused = False
      transferFactoryCid = factoryInterfaceCid
      expectedAdmin = admin
  pure PurchaseFixture with
    payer
    agent
    provider
    admin
    outsider
    now
    instrumentId
    factoryCid
    holdingCid
    holdingInterfaceCid
    capabilityCid

purchaseOptions : PurchaseFixture -> Script SubmitOptions
purchaseOptions PurchaseFixture{payer; agent; admin; factoryCid; holdingCid} = do
  Some factoryDisclosure <- queryDisclosure admin factoryCid
  Some holdingDisclosure <- queryDisclosure payer holdingCid
  pure (actAs agent <> discloseMany [factoryDisclosure, holdingDisclosure])

purchaseCommands : PurchaseFixture -> Commands PurchaseResult
purchaseCommands PurchaseFixture{provider; now; holdingInterfaceCid; capabilityCid} =
  exerciseCmd capabilityCid Purchase with
    attemptId = "sha256:attempt"
    purchaseCommitment = "sha256:purchase"
    requestCommitment = "sha256:request"
    challengeId = "sha256:challenge"
    resourceHash = "sha256:resource"
    recipient = provider
    amount = 2.0
    requestedAt = now
    executeBefore = addRelTime now (hours 1)
    inputHoldingCids = [holdingInterfaceCid]
    extraArgs = Metadata.ExtraArgs with
      context = Metadata.emptyChoiceContext
      meta = Metadata.emptyMetadata
    expectedRevision = 0

assertPurchaseUnchanged : PurchaseFixture -> Script ()
assertPurchaseUnchanged PurchaseFixture{payer; provider; capabilityCid; holdingCid} = do
  Some capability <- queryContractId payer capabilityCid
  assert (capability.revision == 0)
  assert (capability.remainingAllowance == 5.0)
  Some _ <- queryContractId payer holdingCid
  contexts <- query @PurchaseContext payer
  receiverHoldings <- query @MockHolding provider
  pendingInstructions <- query @MockTransferInstruction payer
  assert (null contexts)
  assert (null receiverHoldings)
  assert (null pendingInstructions)
  pure ()
