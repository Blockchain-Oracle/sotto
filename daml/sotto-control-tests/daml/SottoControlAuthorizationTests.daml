module SottoControlAuthorizationTests where

import DA.Time (addRelTime, hours)
import Daml.Script
import Sotto.Control.PrivacyProbe
import SottoControlTestSupport

authorizationLifecycle : Script ()
authorizationLifecycle = do
  parties@ProbeParties{owner; agent; payer; provider; outsider} <- allocateProbeParties
  now <- getTime
  policyCid <- createPolicy parties (addRelTime now (hours 1)) 3.0 10.0

  submitMustFail owner do
    exerciseCmd policyCid Consume with
      attemptId = "attempt-owner-only"
      requestCommitment = testRequestCommitment
      resourceHash = testResourceHash
      recipient = provider
      amount = 2.0
  submitMustFail outsider do
    exerciseCmd policyCid Revoke

  result <- consumePolicy parties policyCid "attempt-1" 2.0
  Some reduced <- queryContractId payer result.policyCid
  assert (reduced.remainingLimit == 8.0)
  assert (reduced.revision == 1)
  assert (reduced.usedAttemptIds == ["attempt-1"])

  submitMustFail (actAs [agent, payer]) do
    exerciseCmd policyCid Consume with
      attemptId = "attempt-stale"
      requestCommitment = testRequestCommitment
      resourceHash = testResourceHash
      recipient = provider
      amount = 1.0
  submitMustFail (actAs [agent, payer]) do
    exerciseCmd result.policyCid Consume with
      attemptId = "attempt-1"
      requestCommitment = testRequestCommitment
      resourceHash = testResourceHash
      recipient = provider
      amount = 1.0

  Some unchanged <- queryContractId payer result.policyCid
  assert (unchanged.remainingLimit == 8.0)
  pausedCid <- submit (actAs [owner, payer]) do
    exerciseCmd result.policyCid Pause
  submitMustFail (actAs [agent, payer]) do
    exerciseCmd pausedCid Consume with
      attemptId = "attempt-paused"
      requestCommitment = testRequestCommitment
      resourceHash = testResourceHash
      recipient = provider
      amount = 1.0
  submit owner do exerciseCmd pausedCid Revoke
  None <- queryContractId payer pausedCid
  pure ()
