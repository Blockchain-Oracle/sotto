{
  "name": "sotto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": "11.12.0"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "node scripts/build-workspaces.mjs",
    "check:claims": "node scripts/check-claims.mjs",
    "check:contamination": "node scripts/check-contamination.mjs",
    "check:context": "node scripts/check-context.mjs",
    "check:env": "node scripts/check-env.mjs",
    "check:files": "node scripts/check-file-length.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:source": "node scripts/check-source.mjs",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "daml:deps": "node scripts/fetch-token-standard-dar.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "spike": "echo 'spike CLIs moved: pnpm --filter @sotto/devnet-payment-spike run <name> (see spikes/*/package.json)'",
    "test": "node scripts/build-workspaces.mjs && corepack pnpm test:unit",
    "test:postgres": "corepack pnpm --filter @sotto/catalog-probe... --filter @sotto/purchase-worker... --filter @sotto/capability-wallet... build && node scripts/run-postgres-integration.mjs",
    "test:unit": "vitest run --exclude '**/*.postgres.test.ts' --exclude '**/*.live.test.ts'",
    "turbo:build": "turbo run build",
    "turbo:test": "turbo run test",
    "typecheck": "tsc --noEmit --pretty false",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@secretlint/secretlint-rule-preset-recommend": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "secretlint": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
