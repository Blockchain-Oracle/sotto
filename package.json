{
  "name": "sotto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": "11.12.0"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "node scripts/build-workspaces.mjs",
    "check:claims": "node scripts/check-claims.mjs",
    "check:contamination": "node scripts/check-contamination.mjs",
    "check:context": "node scripts/check-context.mjs",
    "check:env": "node scripts/check-env.mjs",
    "check:files": "node scripts/check-file-length.mjs",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:source": "node scripts/check-source.mjs",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "daml:deps": "node scripts/fetch-token-standard-dar.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "spike:preflight": "tsx spikes/devnet-payment/src/main.ts",
    "spike:live": "tsx spikes/devnet-payment/src/live-payment.ts",
    "spike:reconcile": "tsx spikes/devnet-payment/src/live-reconciliation.ts",
    "spike:daml": "tsx spikes/devnet-payment/src/live-daml.ts",
    "spike:daml:reconcile": "tsx spikes/devnet-payment/src/live-daml-reconciliation.ts",
    "spike:atomic": "tsx spikes/devnet-payment/src/live-atomic-purchase.ts",
    "spike:atomic:reconcile": "tsx spikes/devnet-payment/src/live-atomic-reconciliation.ts",
    "spike:authority:direct": "tsx spikes/devnet-payment/src/live-five-north-direct-transfer-authority-control.ts",
    "spike:prepare:local": "tsx spikes/devnet-payment/src/local-prepare-smoke-cli.ts",
    "spike:preapproval": "tsx spikes/devnet-payment/src/live-provider-preapproval.ts start",
    "spike:preapproval:recover": "tsx spikes/devnet-payment/src/live-provider-preapproval.ts recover",
    "spike:capability:factory": "tsx spikes/devnet-payment/src/live-capability-factory-observation.ts",
    "spike:capability:start": "tsx spikes/devnet-payment/src/live-capability-bootstrap.ts start",
    "spike:capability:recover": "tsx spikes/devnet-payment/src/live-capability-bootstrap.ts recover",
    "spike:wallet:preflight": "tsx spikes/devnet-payment/src/live-five-north-wallet-preflight.ts",
    "spike:human:prepare": "tsx spikes/devnet-payment/src/live-five-north-human-prepare-cli.ts",
    "spike:human:live": "tsx spikes/devnet-payment/src/live-five-north-human-purchase-cli.ts start",
    "spike:human:recover": "tsx spikes/devnet-payment/src/live-five-north-human-purchase-cli.ts recover",
    "spike:wallet:tap": "tsx spikes/capability-wallet/src/five-north-external-payer-tap-cli.ts",
    "spike:wallet:revoke": "tsx spikes/capability-wallet/src/five-north-capability-revoke-cli.ts",
    "spike:package": "tsx spikes/devnet-payment/src/live-sotto-control-package.ts",
    "test": "node scripts/build-workspaces.mjs && pnpm test:unit",
    "test:postgres": "pnpm --filter @sotto/catalog-probe... build && node scripts/run-postgres-integration.mjs",
    "test:unit": "vitest run --exclude '**/*.postgres.test.ts'",
    "typecheck": "tsc --noEmit --pretty false",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "secretlint": "13.0.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
